# SHACL shapes for the aegis homelab ontology.
#
# Defines validation constraints for all entity labels and relationships
# in the ontology extraction guide (docs/ontology-extraction-guide.md).
#
# Load via POST /shapes:
#   curl -s localhost:3030/shapes -X POST \
#     -H "Content-Type: application/json" \
#     -d '{"action": "load", "name": "aegis-ontology", "turtle": "<contents>"}'

@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix aegis:  <http://aegis.gastown.local/ontology/> .

# ═══════════════════════════════════════════════════════════════════
# Global Constraints
# ═══════════════════════════════════════════════════════════════════

# All aegis entities must have at least one rdfs:label.
aegis:LabelRequiredShape a sh:NodeShape ;
    sh:targetSubjectsOf aegis:runs_on, aegis:depends_on, aegis:managed_by,
        aegis:member_of, aegis:owns, aegis:monitors, aegis:routes_to,
        aegis:connects_to, aegis:deployed_on ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
    ] .

# ════════��══════════════════════════════════════════════════════════
# Infrastructure
# ═════════════════════════════���═════════════════════════════════════

# ── LXCContainer ──────────────────────────────────────────────────
#
# A Proxmox LXC container. Must have a container ID, IP address,
# and hostname.

aegis:LXCContainerShape a sh:NodeShape ;
    sh:targetClass aegis:LXCContainer ;
    sh:property [
        sh:path aegis:ctId ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:ipAddress ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:hostname ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── ProxmoxNode ────────��────────────────────────────────────��────
#
# A physical Proxmox host (e.g., koror, kota).

aegis:ProxmoxNodeShape a sh:NodeShape ;
    sh:targetClass aegis:ProxmoxNode ;
    sh:property [
        sh:path aegis:nodeId ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:role ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── BareMetalHost ─────────────────────────────────────────��──────
#
# A non-Proxmox host (e.g., luvu, a Pi).

aegis:BareMetalHostShape a sh:NodeShape ;
    sh:targetClass aegis:BareMetalHost ;
    sh:property [
        sh:path aegis:ipAddress ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:hostname ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── SystemdService ───────���───────────────────────────────────���───
#
# A systemd unit running on a host or container.

aegis:SystemdServiceShape a sh:NodeShape ;
    sh:targetClass aegis:SystemdService ;
    sh:property [
        sh:path aegis:port ;
        sh:datatype xsd:integer ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:healthEndpoint ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:healthScore ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:maxCount 1 ;
    ] .

# ── WebApplication ───────���───────────────────────────────────────
#
# An HTTP-serving service (Tapestry, Forgejo, Grafana, etc.).

aegis:WebApplicationShape a sh:NodeShape ;
    sh:targetClass aegis:WebApplication ;
    sh:property [
        sh:path aegis:externalUrl ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── DatabaseService ──��───────────────────────────────────────���───
#
# A data store (PostgreSQL, FalkorDB, Dolt, etc.).

aegis:DatabaseServiceShape a sh:NodeShape ;
    sh:targetClass aegis:DatabaseService ;
    sh:property [
        sh:path aegis:dataPath ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:storageBackend ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── ZFSDataset ─────────────────────────────────────���─────────────
#
# A ZFS dataset for storage.

aegis:ZFSDatasetShape a sh:NodeShape ;
    sh:targetClass aegis:ZFSDataset ;
    sh:property [
        sh:path aegis:pool ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:mountpoint ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

# ── ReverseProxyRoute ─────��────────────────────────────────────��─
#
# A Traefik route mapping hostname to backend.

aegis:ReverseProxyRouteShape a sh:NodeShape ;
    sh:targetClass aegis:ReverseProxyRoute ;
    sh:property [
        sh:path aegis:hostname ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:backend ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

# ── NetworkSegment ───────────────────────────────────────────────
#
# A VLAN, subnet, or DNS zone.

aegis:NetworkSegmentShape a sh:NodeShape ;
    sh:targetClass aegis:NetworkSegment ;
    sh:property [
        sh:path aegis:subnet ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:gateway ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path aegis:purpose ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

