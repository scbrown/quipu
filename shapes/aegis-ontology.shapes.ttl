# ═════���══════════════════════════════════════��══════════════════════
# Relationship Constraints
# ═══════════════════════════════════════════════════════════════════
#
# These PropertyShapes constrain relationship edges to valid
# domain/range combinations.

# runs_on: service/container → infrastructure host
aegis:RunsOnShape a sh:PropertyShape ;
    sh:path aegis:runs_on ;
    sh:or (
        [ sh:class aegis:ProxmoxNode ]
        [ sh:class aegis:BareMetalHost ]
        [ sh:class aegis:LXCContainer ]
    ) .

# depends_on: any entity → any entity
aegis:DependsOnShape a sh:PropertyShape ;
    sh:path aegis:depends_on .

# connects_to: any entity → any entity (network/API)
aegis:ConnectsToShape a sh:PropertyShape ;
    sh:path aegis:connects_to .

# managed_by: entity → CrewMember or Person
aegis:ManagedByShape a sh:PropertyShape ;
    sh:path aegis:managed_by ;
    sh:or (
        [ sh:class aegis:CrewMember ]
        [ sh:class aegis:Person ]
    ) .

# member_of: entity → Rig or group
aegis:MemberOfShape a sh:PropertyShape ;
    sh:path aegis:member_of ;
    sh:class aegis:Rig .

# reports_to: CrewMember → CrewMember
aegis:ReportsToShape a sh:PropertyShape ;
    sh:path aegis:reports_to ;
    sh:class aegis:CrewMember .

# backs_up: storage → entity
aegis:BacksUpShape a sh:PropertyShape ;
    sh:path aegis:backs_up .

# routes_to: ReverseProxyRoute → service
aegis:RoutesToShape a sh:PropertyShape ;
    sh:path aegis:routes_to .

# monitors: monitoring service → entity
aegis:MonitorsShape a sh:PropertyShape ;
    sh:path aegis:monitors .

# applies_to: Directive/DecisionRecord → entity
aegis:AppliesToShape a sh:PropertyShape ;
    sh:path aegis:applies_to .

# derived_from: provenance link
aegis:DerivedFromShape a sh:PropertyShape ;
    sh:path aegis:derived_from .

# deployed_on: temporal deployment (value is dateTime)
aegis:DeployedOnShape a sh:PropertyShape ;
    sh:path aegis:deployed_on ;
    sh:datatype xsd:dateTime .

# owns: Person → entity (domain ownership)
aegis:OwnsShape a sh:PropertyShape ;
    sh:path aegis:owns .

# committed_to: GitCommit → GitRepo
aegis:CommittedToShape a sh:PropertyShape ;
    sh:path aegis:committed_to ;
    sh:class aegis:GitRepo .

# authored_by: GitCommit/Bead → Person/CrewMember
aegis:AuthoredByShape a sh:PropertyShape ;
    sh:path aegis:authored_by ;
    sh:or (
        [ sh:class aegis:Person ]
        [ sh:class aegis:CrewMember ]
    ) .

# modifies: GitCommit → entity
aegis:ModifiesShape a sh:PropertyShape ;
    sh:path aegis:modifies .

# implements: GitCommit → Bead
aegis:ImplementsShape a sh:PropertyShape ;
    sh:path aegis:implements ;
    sh:class aegis:Bead .

# triggered_by: entity → CronJob/Script
aegis:TriggeredByShape a sh:PropertyShape ;
    sh:path aegis:triggered_by ;
    sh:or (
        [ sh:class aegis:CronJob ]
        [ sh:class aegis:Script ]
    ) .

# configured_in: entity → ConfigFile/AnsibleRole
aegis:ConfiguredInShape a sh:PropertyShape ;
    sh:path aegis:configured_in ;
    sh:or (
        [ sh:class aegis:ConfigFile ]
        [ sh:class aegis:AnsibleRole ]
    ) .
